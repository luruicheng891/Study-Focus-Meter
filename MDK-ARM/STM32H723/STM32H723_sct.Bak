LR_IROM1 0x08000000 0x00100000  {    ; load region size_region
  ER_IROM1 0x08000000 0x00100000  {  ; load address = execution address
   *.o (RESET, +First)
   *(InRoot$$Sections)
   .ANY (+RO)
   .ANY (+XO)
  }
  RW_IRAM1 0x20000000 0x00020000  {  ; DTCM 128KB: 快, 优先放代码/栈/小数据
   .ANY (+RW +ZI)
  }
  RW_IRAM2 0x24000000 0x00050000  {  ; AXI SRAM 320KB: 装不下的溢出到这里
   *(.RAM_AXI)
   .ANY (+RW +ZI)
  }
}

