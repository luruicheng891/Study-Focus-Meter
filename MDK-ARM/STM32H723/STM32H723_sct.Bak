; *************************************************************
; *** Scatter-Loading Description File for STM32H723ZGT6    ***
; *************************************************************
; Memory Map:
;   Flash:     0x08000000  1MB
;   DTCM:     0x20000000  128KB  (CPU only, NO DMA access!)
;   AXI SRAM:  0x24000000  320KB  (DMA accessible)
;
; Note: Camera DMA buffer at 0x24000000 (115KB, defined in code)
;       LCD DMA buffers at 0x24040000 (2KB, via __attribute__)

LR_IROM1 0x08000000 0x00100000  {    ; load region size_region
  ER_IROM1 0x08000000 0x00100000  {  ; load address = execution address
   *.o (RESET, +First)
   *(InRoot$$Sections)
   .ANY (+RO)
  }
  RW_IRAM1 0x20000000 0x00020000  {  ; DTCM - RW data (stack, heap, normal variables)
   .ANY (+RW +ZI)
  }
  RW_AXIRAM 0x24040000 0x00010000  {  ; AXI SRAM region for DMA buffers
   *(.ARM.__at_0x24040000)            ; LCD DMA ping-pong buffers
  }
}
